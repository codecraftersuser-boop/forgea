# ─── App ───────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-in-production

# ─── Database ──────────────────────────────────────────
DATABASE_URL=postgresql://forgea:forgea@localhost:5432/forgea_db

# ─── Auth (Supabase) ───────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# ─── OAuth ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── Frontend ──────────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ─── CORS ──────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Email / SMTP ──────────────────────────────────────
# Leave empty in development — reset link will print to backend console logs
# Gmail example: SMTP_HOST=smtp.gmail.com, PORT=587, use an App Password
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=true

# ─── URLs ──────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
